# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finance_dashboard"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# Plaid (Sandbox)
PLAID_CLIENT_ID="your_plaid_client_id"
PLAID_SECRET="your_plaid_secret"
PLAID_ENV="sandbox"
PLAID_WEBHOOK_URL="http://localhost:3000/api/webhooks/plaid"

# Encryption
ENCRYPTION_KEY="generate-a-32-byte-hex-key-here-use-openssl-rand-hex-32"

# NextAuth
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# ML Service
ML_SERVICE_URL="http://localhost:8000"

# App
NODE_ENV="development"
